# Copy to .env.local and adjust values for your machine.

# Postgres credentials for local Iceberg JDBC catalog
POSTGRES_DB=iceberg_catalog
POSTGRES_USER=iceberg_user
POSTGRES_PASSWORD=iceberg_password

# Flink -> Iceberg JDBC credentials (defaults to Postgres values)
ICEBERG_JDBC_USER=iceberg_user
ICEBERG_JDBC_PASSWORD=iceberg_password